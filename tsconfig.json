{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "lib": ["ES2020"],
    "paths": {
      "@aspect/wdk-v2-utils": ["../wdk-v2-utils/src"],
      "@aspect/wdk-v2-core": ["../wdk-v2-core/src"]
    }
  },
  "include": ["src/**/*"]
}
